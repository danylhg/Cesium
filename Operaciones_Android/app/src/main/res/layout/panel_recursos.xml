<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:paddingHorizontal="12dp"
    android:paddingBottom="8dp">

    <TextView
        android:id="@+id/recursosTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:letterSpacing="0.15"
        android:paddingTop="8dp"
        android:paddingBottom="4dp"
        android:text="RECURSOS ASIGNADOS"
        android:textColor="#94a3b8"
        android:textSize="10sp" />

    <LinearLayout
        android:id="@+id/recursosTabs"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:layout_marginTop="2dp"
        android:layout_marginBottom="6dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tabRecursosVehiculos"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/bg_resource_tab_selected"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="Vehiculos"
            android:textColor="#F8FAFC"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tabRecursosEquipos"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:background="@drawable/bg_resource_tab"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="Equipos"
            android:textColor="#94A3B8"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tabRecursosDispositivos"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:background="@drawable/bg_resource_tab"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="Dispositivos"
            android:textColor="#94A3B8"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tabRecursosPersonal"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:background="@drawable/bg_resource_tab"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="Personal"
            android:textColor="#94A3B8"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:id="@+id/recursosList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
    </ScrollView>
</LinearLayout>
