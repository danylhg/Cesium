<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_chat_sheet"
    android:orientation="vertical"
    android:paddingBottom="18dp">

    <View
        android:layout_width="44dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="12dp"
        android:background="#2C4F4B" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="16dp"
        android:paddingBottom="2dp"
        android:text="Seleccionar chat"
        android:textColor="#EEFFF9"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="16dp"
        android:paddingBottom="10dp"
        android:text="Canales grupales y destinatarios especificos"
        android:textColor="#9FB3BF"
        android:textSize="12sp" />

    <LinearLayout
        android:id="@+id/sheetChannelList"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical" />

    <Spinner
        android:id="@+id/sheetTargetSpinner"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_chat_input"
        android:paddingHorizontal="12dp"
        android:popupBackground="#18302E"
        android:visibility="gone" />

    <Button
        android:id="@+id/sheetApplyBtn"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="14dp"
        android:backgroundTint="#00A57B"
        android:stateListAnimator="@null"
        android:text="Abrir chat"
        android:textColor="#FFFFFF" />
</LinearLayout>
