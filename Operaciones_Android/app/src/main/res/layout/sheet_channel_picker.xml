<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#07111f"
    android:paddingBottom="18dp">

    <!-- Handle -->
    <View
        android:layout_width="44dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="12dp"
        android:background="#26384f"/>

    <!-- Título -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Seleccionar chat"
        android:textColor="#f8fafc"
        android:textSize="18sp"
        android:textStyle="bold"
        android:paddingHorizontal="16dp"
        android:paddingBottom="2dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Grupales y personal especifico"
        android:textColor="#94a3b8"
        android:textSize="12sp"
        android:paddingHorizontal="16dp"
        android:paddingBottom="10dp"/>

    <!-- Lista de canales (filas generadas en código) -->
    <LinearLayout
        android:id="@+id/sheetChannelList"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"/>

    <!-- Selector de target específico -->
    <Spinner
        android:id="@+id/sheetTargetSpinner"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_chat_input"
        android:paddingHorizontal="12dp"
        android:visibility="gone"
        android:popupBackground="#1e293b"/>

    <!-- Botón aplicar -->
    <Button
        android:id="@+id/sheetApplyBtn"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="14dp"
        android:text="Abrir chat"
        android:textColor="#ffffff"
        android:backgroundTint="#14b8a6"
        android:stateListAnimator="@null"/>

</LinearLayout>
