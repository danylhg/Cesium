<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0a0f1e">
    <TextView
        android:id="@+id/connectionBanner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:background="#B71C1C"
        android:elevation="12dp"
        android:gravity="center"
        android:paddingHorizontal="16dp"
        android:paddingVertical="10dp"
        android:text="Se perdio la conexion con el servidor."
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:visibility="gone" />

    <!-- Mapa Cesium — pantalla completa -->
    <WebView
        android:id="@+id/cesiumWebView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <!-- Barra de herramientas de dibujo libre (flotante, esquina superior derecha) -->
    <LinearLayout
        android:id="@+id/drawingToolbar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="12dp"
        android:orientation="vertical"
        android:elevation="10dp"
        android:background="#CC0d1526"
        android:padding="6dp">

        <TextView
            android:id="@+id/btnPencil"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:gravity="center"
            android:text="✏️"
            android:textSize="22sp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless"/>

        <TextView
            android:id="@+id/btnEraser"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:gravity="center"
            android:text="🧹"
            android:textSize="22sp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:layout_marginTop="4dp"/>

    </LinearLayout>

    <!-- Panel inferior deslizable -->
    <LinearLayout
        android:id="@+id/bottomPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="#E6111827"
        android:elevation="8dp">

        <!-- Handle / drag indicator -->
        <View
            android:id="@+id/panelHandle"
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="4dp"
            android:background="#475569"/>
        <!-- android:clickable="false" eliminado — es el valor por defecto para View -->

        <!-- Contenedor del contenido del panel.
             altura dinámica: wrap_content + maxHeight controlado desde Kotlin con
             panelContent.maxHeight = (resources.displayMetrics.heightPixels * 0.40).toInt()
             Así se adapta a pantallas pequeñas y grandes sin valor fijo. -->
        <FrameLayout
            android:id="@+id/panelContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"/>

        <!-- Barra de navegación inferior (5 botones) -->
        <LinearLayout
            android:id="@+id/navBar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:background="#0d1526">

            <!-- Botón Operación -->
            <LinearLayout
                android:id="@+id/btnNavOperation"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground">
                <TextView
                    android:id="@+id/iconNavOperation"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📋"
                    android:textSize="20sp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Operación"
                    android:textColor="#64748b"
                    android:textSize="10sp"/>
            </LinearLayout>

            <!-- Botón Mensajes -->
            <LinearLayout
                android:id="@+id/btnNavChat"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground">
                <TextView
                    android:id="@+id/iconNavChat"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💬"
                    android:textSize="20sp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mensajes"
                    android:textColor="#64748b"
                    android:textSize="10sp"/>
            </LinearLayout>

            <!-- Botón Personal -->
            <LinearLayout
                android:id="@+id/btnNavPersonal"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground">
                <TextView
                    android:id="@+id/iconNavPersonal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="👤"
                    android:textSize="20sp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Personal"
                    android:textColor="#64748b"
                    android:textSize="10sp"/>
            </LinearLayout>

            <!-- Botón Vehículos -->
            <LinearLayout
                android:id="@+id/btnNavVehiculos"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground">
                <TextView
                    android:id="@+id/iconNavVehiculos"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🚗"
                    android:textSize="20sp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Vehículos"

                    android:textColor="#64748b"
                    android:textSize="10sp"/>
            </LinearLayout>

            <!-- Botón Vehículos/Equipo -->
            <LinearLayout
                android:id="@+id/btnNavEquipos"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground">

                <TextView
                    android:id="@+id/iconNavEquipos"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🧰"
                    android:textSize="20sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Equipos"
                    android:textColor="#64748b"
                    android:textSize="10sp"/>
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
