<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0a0f1e">
    <TextView
        android:id="@+id/connectionBanner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:background="#B71C1C"
        android:elevation="12dp"
        android:gravity="center"
        android:paddingHorizontal="16dp"
        android:paddingVertical="10dp"
        android:text="Se perdio la conexion con el servidor."
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:visibility="gone" />

    <!-- Mapa Cesium — pantalla completa -->
    <WebView
        android:id="@+id/cesiumWebView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <!-- Barra de herramientas de dibujo libre (flotante, esquina superior derecha) -->
    <LinearLayout
        android:id="@+id/drawingToolbar"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="12dp"
        android:orientation="vertical"
        android:elevation="10dp"
        android:background="#CC0d1526"
        android:padding="6dp">

        <TextView
            android:id="@+id/btnPencil"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:gravity="center"
            android:text="✏️"
            android:textSize="22sp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless"/>

        <TextView
            android:id="@+id/btnEraser"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:gravity="center"
            android:text="🧹"
            android:textSize="22sp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:layout_marginTop="4dp"/>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/objectToolsContainer"
        android:layout_width="286dp"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="12dp"
        android:elevation="16dp"
        android:gravity="end"
        android:orientation="vertical">

        <TextView
            android:id="@+id/btnObjectTools"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:background="@drawable/bg_object_tools_button"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:minWidth="104dp"
            android:paddingHorizontal="16dp"
            android:text="Objetos &#x25BE;"
            android:textColor="#F8FAFC"
            android:textSize="14sp"
            android:textStyle="bold" />

        <ScrollView
            android:id="@+id/objectToolsMenu"
            android:layout_width="286dp"
            android:layout_height="430dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_object_tools_menu"
            android:fillViewport="false"
            android:overScrollMode="ifContentScrolls"
            android:padding="10dp"
            android:scrollbarStyle="insideInset"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingBottom="8dp"
                    android:text="SELECCI&#xD3;N DE TIPO DE OBJETO"
                    android:textColor="#CBD5E1"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/objectToolSelection"
                    android:layout_width="match_parent"
                    android:layout_height="38dp"
                    android:background="@drawable/bg_object_tools_menu_item"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="12dp"
                    android:text="Selecciona herramienta..."
                    android:textColor="#E2E8F0"
                    android:textSize="13sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingTop="12dp"
                    android:paddingBottom="4dp"
                    android:text="DIBUJO LIBRE"
                    android:textColor="#38BDF8"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/itemToolPencil"
                    android:layout_width="match_parent"
                    android:layout_height="42dp"
                    android:background="@drawable/bg_object_tools_menu_item"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="12dp"
                    android:text="&#x270F;&#xFE0F; L&#xE1;piz (dibujo libre)"
                    android:textColor="#F8FAFC"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/itemToolEraser"
                    android:layout_width="match_parent"
                    android:layout_height="42dp"
                    android:layout_marginTop="4dp"
                    android:background="@drawable/bg_object_tools_menu_item"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="12dp"
                    android:text="&#x1F58C;&#xFE0F; Goma de borrar"
                    android:textColor="#F8FAFC"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingTop="12dp"
                    android:paddingBottom="4dp"
                    android:text="PUNTOS DE INTER&#xC9;S"
                    android:textColor="#38BDF8"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/itemToolMil"
                    android:layout_width="match_parent"
                    android:layout_height="42dp"
                    android:background="@drawable/bg_object_tools_menu_item"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="12dp"
                    android:text="S&#xED;mbolo Militar (MIL)"
                    android:textColor="#F8FAFC"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/itemToolPoi"
                    android:layout_width="match_parent"
                    android:layout_height="42dp"
                    android:layout_marginTop="4dp"
                    android:background="@drawable/bg_object_tools_menu_item"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="12dp"
                    android:text="Puntos de Inter&#xE9;s"
                    android:textColor="#F8FAFC"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingTop="12dp"
                    android:paddingBottom="4dp"
                    android:text="&#xC1;REAS DE INTER&#xC9;S"
                    android:textColor="#38BDF8"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/itemToolPolygon"
                    android:layout_width="match_parent"
                    android:layout_height="42dp"
                    android:background="@drawable/bg_object_tools_menu_item"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="12dp"
                    android:text="Pol&#xED;gono T&#xE1;ctico"
                    android:textColor="#F8FAFC"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/itemToolCircle"
                    android:layout_width="match_parent"
                    android:layout_height="42dp"
                    android:layout_marginTop="4dp"
                    android:background="@drawable/bg_object_tools_menu_item"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="12dp"
                    android:text="C&#xED;rculo de cobertura"
                    android:textColor="#F8FAFC"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/itemToolRoute"
                    android:layout_width="match_parent"
                    android:layout_height="42dp"
                    android:layout_marginTop="4dp"
                    android:background="@drawable/bg_object_tools_menu_item"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="12dp"
                    android:text="L&#xED;nea T&#xE1;ctica (Ruta)"
                    android:textColor="#F8FAFC"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingTop="12dp"
                    android:paddingBottom="4dp"
                    android:text="OTROS"
                    android:textColor="#38BDF8"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/itemToolBuilding"
                    android:layout_width="match_parent"
                    android:layout_height="42dp"
                    android:background="@drawable/bg_object_tools_menu_item"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="12dp"
                    android:text="&#x1F3E0; Edificio / Estructura"
                    android:textColor="#F8FAFC"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/itemToolLabel"
                    android:layout_width="match_parent"
                    android:layout_height="42dp"
                    android:layout_marginTop="4dp"
                    android:background="@drawable/bg_object_tools_menu_item"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="12dp"
                    android:text="&#x1F3F7;&#xFE0F; Etiqueta"
                    android:textColor="#F8FAFC"
                    android:textSize="14sp" />

            </LinearLayout>
        </ScrollView>
    </LinearLayout>

    <ImageButton
        android:id="@+id/btnDeleteSelectedObject"
        android:layout_width="54dp"
        android:layout_height="54dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="72dp"
        android:layout_marginEnd="16dp"
        android:background="@drawable/bg_fab_delete"
        android:clickable="true"
        android:contentDescription="Eliminar objeto seleccionado"
        android:elevation="18dp"
        android:focusable="true"
        android:padding="13dp"
        android:scaleType="centerInside"
        android:src="@android:drawable/ic_menu_delete"
        android:tint="#FFFFFF"
        android:visibility="gone" />

    <!-- Panel inferior deslizable -->
    <LinearLayout
        android:id="@+id/bottomPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="#E6111827"
        android:clickable="true"
        android:elevation="8dp">

        <!-- Handle / drag indicator -->
        <View
            android:id="@+id/panelHandle"
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="4dp"
            android:background="#475569"/>
        <!-- android:clickable="false" eliminado — es el valor por defecto para View -->

        <!-- Contenedor del contenido del panel.
             altura dinámica: wrap_content + maxHeight controlado desde Kotlin con
             panelContent.maxHeight = (resources.displayMetrics.heightPixels * 0.40).toInt()
             Así se adapta a pantallas pequeñas y grandes sin valor fijo. -->
        <FrameLayout
            android:id="@+id/panelContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"/>

        <!-- Barra de navegación inferior (5 botones) -->
        <LinearLayout
            android:id="@+id/navBar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:background="#0d1526">

            <!-- Botón Operación -->
            <LinearLayout
                android:id="@+id/btnNavOperation"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground">
                <TextView
                    android:id="@+id/iconNavOperation"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📋"
                    android:textSize="20sp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Operación"
                    android:textColor="#64748b"
                    android:textSize="10sp"/>
            </LinearLayout>

            <!-- Botón Mensajes -->
            <LinearLayout
                android:id="@+id/btnNavChat"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground">
                <TextView
                    android:id="@+id/iconNavChat"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💬"
                    android:textSize="20sp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mensajes"
                    android:textColor="#64748b"
                    android:textSize="10sp"/>
            </LinearLayout>

            <!-- Botón Personal -->
            <LinearLayout
                android:id="@+id/btnNavPersonal"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground">
                <TextView
                    android:id="@+id/iconNavPersonal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="👤"
                    android:textSize="20sp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Personal"
                    android:textColor="#64748b"
                    android:textSize="10sp"/>
            </LinearLayout>

            <!-- Botón Vehículos -->
            <LinearLayout
                android:id="@+id/btnNavVehiculos"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground">
                <TextView
                    android:id="@+id/iconNavVehiculos"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🚗"
                    android:textSize="20sp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Vehículos"

                    android:textColor="#64748b"
                    android:textSize="10sp"/>
            </LinearLayout>

            <!-- Botón Vehículos/Equipo -->
            <LinearLayout
                android:id="@+id/btnNavEquipos"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground">

                <TextView
                    android:id="@+id/iconNavEquipos"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🧰"
                    android:textSize="20sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Equipos"
                    android:textColor="#64748b"
                    android:textSize="10sp"/>
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>

    <ImageButton
        android:id="@+id/btnMyLocation"
        android:layout_width="54dp"
        android:layout_height="54dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="88dp"
        android:background="@drawable/bg_fab_location"
        android:clickable="true"
        android:contentDescription="Centrar en mi ubicacion"
        android:elevation="4dp"
        android:focusable="true"
        android:padding="13dp"
        android:scaleType="centerInside"
        android:stateListAnimator="@null"
        android:src="@android:drawable/ic_menu_mylocation"
        android:tint="#0f172a" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
