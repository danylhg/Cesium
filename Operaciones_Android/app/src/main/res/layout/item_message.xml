<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingHorizontal="10dp"
    android:paddingVertical="3dp">

    <LinearLayout
        android:id="@+id/bubble"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="start"
        android:orientation="vertical"
        android:background="@drawable/bg_bubble_recv"
        android:paddingHorizontal="12dp"
        android:paddingVertical="7dp">

        <TextView
            android:id="@+id/msgMeta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#8aa0b8"
            android:textSize="10sp"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/msgText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#e2e8f0"
            android:textSize="14sp"
            android:lineSpacingExtra="2dp"/>

        <ImageView
            android:id="@+id/msgImageAttachment"
            android:layout_width="220dp"
            android:layout_height="150dp"
            android:layout_marginTop="6dp"
            android:adjustViewBounds="true"
            android:background="#0f172a"
            android:contentDescription="Imagen adjunta"
            android:scaleType="centerCrop"
            android:visibility="gone" />

        <VideoView
            android:id="@+id/msgVideoAttachment"
            android:layout_width="220dp"
            android:layout_height="150dp"
            android:layout_marginTop="6dp"
            android:background="#0f172a"
            android:visibility="gone" />

        <TextView
            android:id="@+id/msgAudioAttachment"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_dest_btn"
            android:paddingHorizontal="10dp"
            android:paddingVertical="7dp"
            android:textColor="#bfdbfe"
            android:textSize="12sp"
            android:visibility="gone"/>

        <TextView
            android:id="@+id/msgAttachment"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_dest_btn"
            android:paddingHorizontal="10dp"
            android:paddingVertical="7dp"
            android:textColor="#bfdbfe"
            android:textSize="12sp"
            android:visibility="gone"/>

    </LinearLayout>

</FrameLayout>
