<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_chat_screen"
    android:paddingHorizontal="8dp"
    android:paddingTop="2dp"
    android:paddingBottom="6dp">

    <LinearLayout
        android:id="@+id/chatListScreen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="8dp"
            android:paddingTop="8dp"
            android:paddingBottom="2dp"
            android:text="Chats"
            android:textColor="#00F0A8"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="8dp"
            android:paddingBottom="6dp"
            android:text="Selecciona una conversacion"
            android:textColor="#9FB3BF"
            android:textSize="12sp" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:fillViewport="true"
            android:overScrollMode="ifContentScrolls"
            android:paddingBottom="4dp">

            <LinearLayout
                android:id="@+id/chatListContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </ScrollView>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/chatConversationScreen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/channelSelector"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:background="@drawable/bg_chat_header"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="2dp">

            <TextView
                android:id="@+id/chatBackBtn"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:contentDescription="Volver a chats"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:gravity="center"
                android:text="&#x2039;"
                android:textColor="#EEFFF9"
                android:textSize="30sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/chatAvatar"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:background="@drawable/bg_chat_avatar"
                android:gravity="center"
                android:text="T"
                android:textColor="#00F0A8"
                android:textSize="13sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/chatTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="Todos"
                    android:textColor="#EEFFF9"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/chatSubtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="Operacion completa"
                    android:textColor="#9FB3BF"
                    android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="2dp"
            android:layout_weight="1"
            android:background="@drawable/bg_chat_messages">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/chatRecycler"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:paddingHorizontal="0dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp" />

            <TextView
                android:id="@+id/chatEmptyState"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:padding="18dp"
                android:text="Sin mensajes en este chat"
                android:textColor="#82999B"
                android:textSize="13sp"
                android:textStyle="bold"
                android:visibility="gone" />
        </FrameLayout>

        <HorizontalScrollView
            android:id="@+id/quickRepliesScroll"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:overScrollMode="never"
            android:scrollbars="none"
            android:visibility="gone">

            <LinearLayout
                android:id="@+id/quickRepliesContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal" />
        </HorizontalScrollView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:background="@drawable/bg_chat_composer"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="5dp"
            android:paddingVertical="4dp">

            <ImageButton
                android:id="@+id/cameraBtn"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:background="@drawable/bg_chat_icon_button"
                android:contentDescription="Tomar foto o video"
                android:padding="9dp"
                android:scaleType="centerInside"
                android:src="@android:drawable/ic_menu_camera"
                android:tint="#E8FFF8" />

            <EditText
                android:id="@+id/msgInput"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_weight="1"
                android:background="@drawable/bg_chat_input"
                android:gravity="center_vertical"
                android:hint="Escribe un mensaje"
                android:imeOptions="actionSend"
                android:inputType="textMultiLine|textCapSentences"
                android:maxHeight="96dp"
                android:maxLines="4"
                android:minHeight="38dp"
                android:paddingHorizontal="10dp"
                android:paddingVertical="7dp"
                android:textColor="#EEFFF9"
                android:textColorHint="#7D9198"
                android:textSize="14sp" />

            <ImageButton
                android:id="@+id/sendBtn"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:layout_marginStart="4dp"
                android:background="@drawable/bg_chat_send_button"
                android:contentDescription="Enviar"
                android:padding="8dp"
                android:scaleType="centerInside"
                android:src="@android:drawable/ic_menu_send"
                android:tint="#00F0A8" />

            <TextView
                android:id="@+id/btnAlert"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_marginStart="2dp"
                android:background="@drawable/bg_chat_alert"
                android:clickable="true"
                android:contentDescription="Enviar mensaje urgente"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:gravity="center"
                android:text="!"
                android:textColor="#FFB4B4"
                android:textSize="16sp"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/voiceBtn"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:layout_marginStart="4dp"
                android:background="@drawable/bg_chat_icon_button"
                android:contentDescription="Mensaje de voz"
                android:padding="9dp"
                android:scaleType="centerInside"
                android:src="@android:drawable/ic_btn_speak_now"
                android:tint="#E8FFF8" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
