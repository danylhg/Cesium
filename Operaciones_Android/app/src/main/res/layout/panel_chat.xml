<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_chat_screen">

    <!-- ── Header ───────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/channelSelector"
        android:layout_width="match_parent"
        android:layout_height="62dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="14dp"
        android:background="@drawable/bg_chat_header">

        <TextView
            android:id="@+id/chatAvatar"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_chat_avatar"
            android:gravity="center"
            android:text="T"
            android:textColor="#ffffff"
            android:textSize="15sp"
            android:textStyle="bold"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/chatTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Todos"
                android:textColor="#e2e8f0"
                android:textSize="16sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"/>

            <TextView
                android:id="@+id/chatSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Operacion completa"
                android:textColor="#94a3b8"
                android:textSize="11sp"
                android:maxLines="1"
                android:ellipsize="end"/>
        </LinearLayout>

        <TextView
            android:id="@+id/destBtn"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:minWidth="68dp"
            android:background="@drawable/bg_chat_icon_button"
            android:text="Chats"
            android:textColor="#7dd3fc"
            android:textSize="12sp"
            android:gravity="center"
            android:paddingHorizontal="12dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"/>

    </LinearLayout>

    <!-- ── Lista de mensajes ─────────────────────────────────── -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/chatRecycler"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="4dp"
        android:paddingTop="10dp"
        android:paddingBottom="8dp"
        android:clipToPadding="false"/>

    <!-- ── Respuestas rápidas ─────────────────────────────────── -->
    <HorizontalScrollView
        android:id="@+id/quickRepliesScroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:overScrollMode="never"
        android:paddingHorizontal="10dp"
        android:paddingTop="2dp"
        android:paddingBottom="6dp">
        <LinearLayout
            android:id="@+id/quickRepliesContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"/>
    </HorizontalScrollView>

    <!-- ── Destino ────────────────────────────────────────────── -->
    <!-- ── Composición ───────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="8dp"
        android:paddingTop="4dp"
        android:paddingBottom="6dp"
        android:background="@drawable/bg_chat_composer">

        <EditText
            android:id="@+id/msgInput"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1"
            android:hint="Mensaje"
            android:textColor="#e2e8f0"
            android:textColorHint="#64748b"
            android:background="@drawable/bg_chat_input"
            android:paddingHorizontal="16dp"
            android:inputType="text"
            android:textSize="14sp"
            android:imeOptions="actionSend"/>

        <ImageButton
            android:id="@+id/voiceBtn"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:layout_marginStart="6dp"
            android:background="@drawable/bg_chat_icon_button"
            android:src="@android:drawable/ic_btn_speak_now"
            android:contentDescription="Mensaje de voz"
            android:tint="#cbd5e1"
            android:scaleType="centerInside"
            android:padding="10dp"/>

        <ImageButton
            android:id="@+id/cameraBtn"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:layout_marginStart="6dp"
            android:background="@drawable/bg_chat_icon_button"
            android:src="@android:drawable/ic_menu_camera"
            android:contentDescription="Tomar foto o video"
            android:tint="#cbd5e1"
            android:scaleType="centerInside"
            android:padding="10dp"/>

        <ImageButton
            android:id="@+id/sendBtn"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:layout_marginStart="6dp"
            android:background="@drawable/bg_chat_send_button"
            android:src="@android:drawable/ic_menu_send"
            android:contentDescription="Enviar"
            android:tint="#ffffff"
            android:scaleType="centerInside"
            android:padding="10dp"/>

    </LinearLayout>

    <!-- ── Alerta (discreta, solo texto) ─────────────────────── -->
    <TextView
        android:id="@+id/btnAlert"
        android:layout_width="wrap_content"
        android:layout_height="32dp"
        android:layout_gravity="end"
        android:layout_marginEnd="10dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/bg_chat_alert"
        android:text="Urgente"
        android:textColor="#fca5a5"
        android:textSize="12sp"
        android:gravity="center"
        android:paddingHorizontal="14dp"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground"/>

</LinearLayout>
