<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:paddingHorizontal="12dp"
    android:paddingBottom="8dp">

    <!-- Header -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="MENSAJES"
        android:textColor="#94a3b8"
        android:textSize="10sp"
        android:letterSpacing="0.15"
        android:paddingTop="8dp"
        android:paddingBottom="6dp"/>

    <!-- Lista de mensajes -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/chatRecycler"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"/>

    <!-- Predetermined messages (Quick replies) -->
    <HorizontalScrollView
        android:id="@+id/quickRepliesScroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:overScrollMode="never"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="4dp">
        <LinearLayout
            android:id="@+id/quickRepliesContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingVertical="4dp"/>
    </HorizontalScrollView>

    <!-- Input row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="4dp">

        <!-- Campo de texto -->
        <EditText
            android:id="@+id/msgInput"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:hint="Escribe un mensaje..."
            android:textColor="#e2e8f0"
            android:textColorHint="#475569"
            android:background="#1a2235"
            android:paddingHorizontal="12dp"
            android:inputType="text"
            android:textSize="13sp"/>

        <!-- Botón aviso (rojo) -->
        <ImageButton
            android:id="@+id/btnAlert"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="#7f1d1d"
            android:src="@android:drawable/ic_dialog_alert"
            android:contentDescription="Aviso"
            android:tint="#ef4444"
            android:scaleType="centerInside"
            android:padding="10dp"/>

        <!-- Botón enviar -->
        <ImageButton
            android:id="@+id/sendBtn"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="#1e3a5f"
            android:src="@android:drawable/ic_menu_send"
            android:contentDescription="Enviar"
            android:tint="#3b82f6"
            android:scaleType="centerInside"
            android:padding="10dp"/>

    </LinearLayout>
</LinearLayout>
