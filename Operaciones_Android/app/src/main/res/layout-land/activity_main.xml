<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dash_bg"
    android:orientation="horizontal">

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:id="@+id/mapPane"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:background="@color/dash_bg">

        <WebView
            android:id="@+id/cesiumWebView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <ImageButton
            android:id="@+id/btnMapLayers"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_gravity="top|start"
            android:layout_marginTop="16dp"
            android:layout_marginStart="12dp"
            android:background="@drawable/bg_object_tools_button"
            android:clickable="true"
            android:contentDescription="Tipos de mapa"
            android:elevation="16dp"
            android:focusable="true"
            android:padding="9dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_map_layers" />

        <TextView
            android:id="@+id/connectionBanner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="top"
            android:background="@color/dash_danger"
            android:elevation="12dp"
            android:gravity="center"
            android:paddingHorizontal="16dp"
            android:paddingVertical="0dp"
            android:text="Se perdio la conexion con el servidor."
            android:textColor="@color/dash_text"
            android:textStyle="bold"
            android:visibility="gone"
            android:maxHeight="0dp" />

        <LinearLayout
            android:id="@+id/drawingToolbar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="12dp"
            android:background="#CC0d1526"
            android:elevation="10dp"
            android:orientation="vertical"
            android:padding="6dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/btnPencil"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="&#x270F;&#xFE0F;"
                android:textSize="22sp" />

            <TextView
                android:id="@+id/btnEraser"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginTop="4dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="&#x1F9F9;"
                android:textSize="22sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/objectToolsContainer"
            android:layout_width="286dp"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="12dp"
            android:elevation="16dp"
            android:gravity="end"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/btnObjectTools"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_object_tools_button"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:minWidth="104dp"
                    android:paddingHorizontal="16dp"
                    android:text="Objetos &#x25BE;"
                    android:textColor="#F8FAFC"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <ScrollView
                android:id="@+id/objectToolsMenu"
                android:layout_width="286dp"
                android:layout_height="300dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_object_tools_menu"
                android:fillViewport="false"
                android:overScrollMode="ifContentScrolls"
                android:padding="10dp"
                android:scrollbarStyle="insideInset"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingBottom="8dp"
                        android:text="SELECCION DE TIPO DE OBJETO"
                        android:textColor="#CBD5E1"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/objectToolSelection"
                        android:layout_width="match_parent"
                        android:layout_height="38dp"
                        android:background="@drawable/bg_object_tools_menu_item"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="12dp"
                        android:text="Selecciona herramienta..."
                        android:textColor="#E2E8F0"
                        android:textSize="13sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingTop="12dp"
                        android:paddingBottom="4dp"
                        android:text="DIBUJO LIBRE"
                        android:textColor="#38BDF8"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/itemToolPencil"
                        android:layout_width="match_parent"
                        android:layout_height="42dp"
                        android:background="@drawable/bg_object_tools_menu_item"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="12dp"
                        android:text="&#x270F;&#xFE0F; Lapiz (dibujo libre)"
                        android:textColor="#F8FAFC"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/itemToolEraser"
                        android:layout_width="match_parent"
                        android:layout_height="42dp"
                        android:layout_marginTop="4dp"
                        android:background="@drawable/bg_object_tools_menu_item"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="12dp"
                        android:text="&#x1F58C;&#xFE0F; Goma de borrar"
                        android:textColor="#F8FAFC"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingTop="12dp"
                        android:paddingBottom="4dp"
                        android:text="PUNTOS DE INTERES"
                        android:textColor="#38BDF8"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/itemToolMil"
                        android:layout_width="match_parent"
                        android:layout_height="42dp"
                        android:background="@drawable/bg_object_tools_menu_item"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="12dp"
                        android:text="Simbolo Militar (MIL)"
                        android:textColor="#F8FAFC"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/itemToolPoi"
                        android:layout_width="match_parent"
                        android:layout_height="42dp"
                        android:layout_marginTop="4dp"
                        android:background="@drawable/bg_object_tools_menu_item"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="12dp"
                        android:text="Puntos de Interes"
                        android:textColor="#F8FAFC"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingTop="12dp"
                        android:paddingBottom="4dp"
                        android:text="AREAS DE INTERES"
                        android:textColor="#38BDF8"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/itemToolPolygon"
                        android:layout_width="match_parent"
                        android:layout_height="42dp"
                        android:background="@drawable/bg_object_tools_menu_item"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="12dp"
                        android:text="Poligono Tactico"
                        android:textColor="#F8FAFC"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/itemToolCircle"
                        android:layout_width="match_parent"
                        android:layout_height="42dp"
                        android:layout_marginTop="4dp"
                        android:background="@drawable/bg_object_tools_menu_item"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="12dp"
                        android:text="Circulo de cobertura"
                        android:textColor="#F8FAFC"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/itemToolRoute"
                        android:layout_width="match_parent"
                        android:layout_height="42dp"
                        android:layout_marginTop="4dp"
                        android:background="@drawable/bg_object_tools_menu_item"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="12dp"
                        android:text="Linea Tactica (Ruta)"
                        android:textColor="#F8FAFC"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingTop="12dp"
                        android:paddingBottom="4dp"
                        android:text="OTROS"
                        android:textColor="#38BDF8"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/itemToolBuilding"
                        android:layout_width="match_parent"
                        android:layout_height="42dp"
                        android:background="@drawable/bg_object_tools_menu_item"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="12dp"
                        android:text="&#x1F3E0; Edificio / Estructura"
                        android:textColor="#F8FAFC"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/itemToolLabel"
                        android:layout_width="match_parent"
                        android:layout_height="42dp"
                        android:layout_marginTop="4dp"
                        android:background="@drawable/bg_object_tools_menu_item"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="12dp"
                        android:text="&#x1F3F7;&#xFE0F; Etiqueta"
                        android:textColor="#F8FAFC"
                        android:textSize="14sp" />
                </LinearLayout>
            </ScrollView>
        </LinearLayout>

        <ImageButton
            android:id="@+id/btnDeleteSelectedObject"
            android:layout_width="54dp"
            android:layout_height="54dp"
            android:layout_gravity="top|end"
            android:layout_marginTop="72dp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/bg_fab_delete"
            android:clickable="true"
            android:contentDescription="Eliminar objeto seleccionado"
            android:elevation="18dp"
            android:focusable="true"
            android:padding="13dp"
            android:scaleType="centerInside"
            android:src="@android:drawable/ic_menu_delete"
            android:tint="#FFFFFF"
            android:visibility="gone" />

        <ImageButton
            android:id="@+id/btnMyLocation"
            android:layout_width="54dp"
            android:layout_height="54dp"
            android:layout_gravity="bottom|end"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_fab_location"
            android:clickable="true"
            android:contentDescription="Centrar en mi ubicacion"
            android:elevation="4dp"
            android:focusable="true"
            android:padding="13dp"
            android:scaleType="centerInside"
            android:stateListAnimator="@null"
            android:src="@android:drawable/ic_menu_mylocation"
            android:tint="#0f172a" />

        <ImageButton
            android:id="@+id/btnStreamMedia"
            android:layout_width="54dp"
            android:layout_height="54dp"
            android:layout_gravity="bottom|end"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="82dp"
            android:background="@drawable/bg_fab_delete"
            android:clickable="true"
            android:contentDescription="Iniciar transmision de camara y microfono"
            android:elevation="5dp"
            android:focusable="true"
            android:padding="13dp"
            android:scaleType="centerInside"
            android:src="@android:drawable/ic_menu_camera"
            android:tint="#FFFFFF"
            android:visibility="gone" />
    </androidx.coordinatorlayout.widget.CoordinatorLayout>

    <LinearLayout
        android:id="@+id/bottomPanel"
        android:layout_width="340dp"
        android:layout_height="match_parent"
        android:background="#E6111827"
        android:clickable="true"
        android:elevation="8dp"
        android:orientation="vertical">

        <View
            android:id="@+id/panelHandle"
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="4dp"
            android:background="#475569" />

        <LinearLayout
            android:id="@+id/navBar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@color/dash_surface_strong"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/btnNavOperation"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/iconNavOperation"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="&#x1F4CB;"
                    android:textSize="18sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Op."
                    android:textColor="#9FB3BF"
                    android:textSize="10sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnNavChat"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/iconNavChat"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="&#x1F4AC;"
                    android:textSize="18sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chat"
                    android:textColor="#9FB3BF"
                    android:textSize="10sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnNavPersonal"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:id="@+id/iconNavPersonal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="&#x1F464;"
                    android:textSize="18sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pers."
                    android:textColor="#9FB3BF"
                    android:textSize="10sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnNavVehiculos"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/iconNavVehiculos"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="&#x1F9F0;"
                    android:textSize="18sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Rec."
                    android:textColor="#9FB3BF"
                    android:textSize="10sp" />
            </LinearLayout>

        </LinearLayout>

        <FrameLayout
            android:id="@+id/panelContent"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:visibility="gone" />
    </LinearLayout>
</LinearLayout>
